# Copy this file to .env and fill in values for local development

# App
ENVIRONMENT=development
SECRET_KEY=change-me-to-a-random-string
LOG_LEVEL=INFO

# Database
# SQLite for local dev (default if not set):
# DATABASE_URL=sqlite:///./columbia_events.db
# PostgreSQL for production:
# DATABASE_URL=postgresql://user:password@host:5432/columbia_events
DATABASE_URL=sqlite:///./columbia_events.db

# Geocoding (Geocodio — free tier: 2,500 lookups/day)
# Sign up at https://www.geocod.io/
GEOCODIO_API_KEY=

# Sentry error monitoring (optional, free tier)
# Sign up at https://sentry.io/
SENTRY_DSN=
